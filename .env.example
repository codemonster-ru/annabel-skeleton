APP_ENV=local
APP_DEBUG=true

LOG_CHANNEL=file
LOG_FILE=

MAIL_MAILER=log
MAILER_DSN=smtp://localhost:25
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Annabel
MAIL_SENDMAIL_COMMAND="/usr/sbin/sendmail -t -i"

HTTP_CLIENT_BASE_URL=
HTTP_CLIENT_TIMEOUT=30

CACHE_STORE=file
CACHE_PATH=
CACHE_PREFIX=cache:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=0
REDIS_TIMEOUT=2.0

QUEUE_CONNECTION=sync
QUEUE_REDIS_PREFIX=queue:
QUEUE_TABLE=jobs
QUEUE_FAILED_TABLE=failed_jobs
QUEUE_RETRY_AFTER=60
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF=0
QUEUE_TIMEOUT=0

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=annabel
DB_USERNAME=root
DB_PASSWORD=

# Sessions
SESSION_DRIVER=file
SESSION_PATH=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=Lax
SESSION_COOKIE_LIFETIME=86400
SESSION_REDIS_HOST=127.0.0.1
SESSION_REDIS_PORT=6379
SESSION_REDIS_DATABASE=0
SESSION_REDIS_PREFIX=annabel_session:
SESSION_REDIS_TTL=86400

# Security (codemonster-ru/security)
SECURITY_CSRF_ENABLED=true
SECURITY_CSRF_ADD_TO_KERNEL=true
SECURITY_CSRF_VERIFY_JSON=false
SECURITY_CSRF_INPUT_KEY=_token

SECURITY_THROTTLE_ENABLED=true
SECURITY_THROTTLE_ADD_TO_KERNEL=true
SECURITY_THROTTLE_MAX_ATTEMPTS=60
SECURITY_THROTTLE_DECAY_SECONDS=60
SECURITY_THROTTLE_STORAGE=session
SECURITY_THROTTLE_CONNECTION=null
SECURITY_THROTTLE_TABLE=throttle_requests
SECURITY_THROTTLE_REDIS=null
SECURITY_THROTTLE_PREFIX=throttle:
SECURITY_THROTTLE_LOGIN_IP_MAX_ATTEMPTS=60
SECURITY_THROTTLE_LOGIN_IP_DECAY_SECONDS=60
SECURITY_THROTTLE_LOGIN_ACCOUNT_MAX_ATTEMPTS=5
SECURITY_THROTTLE_LOGIN_ACCOUNT_DECAY_SECONDS=300
SECURITY_THROTTLE_LOGIN_ACCOUNT_FIELD=email
SECURITY_THROTTLE_API_MAX_ATTEMPTS=120
SECURITY_THROTTLE_API_DECAY_SECONDS=60
SECURITY_TRUSTED_PROXIES=
