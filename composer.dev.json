{
    "name": "codemonster-ru/annabel-skeleton-dev",
    "description": "Local development manifest for Annabel skeleton inside the monorepo",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.2",
        "codemonster-ru/annabel": "dev-main as 1.14.99",
        "codemonster-ru/config": "dev-main as 2.0.99",
        "codemonster-ru/database": "dev-main as 2.0.99",
        "codemonster-ru/dumper": "dev-main as 1.0.99",
        "codemonster-ru/env": "dev-main as 2.3.99",
        "codemonster-ru/errors": "dev-main as 1.2.99",
        "codemonster-ru/http": "dev-main as 2.0.99",
        "codemonster-ru/razor": "dev-main as 1.1.99",
        "codemonster-ru/router": "dev-main as 2.5.99",
        "codemonster-ru/security": "dev-main as 1.1.99",
        "codemonster-ru/session": "dev-main as 2.0.99",
        "codemonster-ru/support": "dev-main as 1.4.99",
        "codemonster-ru/view": "dev-main as 2.3.99",
        "codemonster-ru/view-php": "dev-main as 2.1.99"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "start": "@php -S localhost:8000 -t public"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
